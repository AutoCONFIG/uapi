FROM golang:1.26-alpine AS builder
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /uapi-relay ./cmd/uapi-relay/

FROM alpine:3.21
RUN apk add --no-cache ca-certificates
COPY --from=builder /uapi-relay /app/uapi-relay
WORKDIR /app
EXPOSE 8081
ENTRYPOINT ["/app/uapi-relay"]
CMD ["-config", "config.yaml"]
